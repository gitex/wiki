3d\u043e\u0441\u0442\u044c - \u044d\u0442\u043e \u043f\u0440\u043e\u0446\u0435\u0441\u0441 \u043e\u0431\u0440\u0430\u0442\u043d\u044b\u0439 \u0441\u0438\u043d\u0445\u0440\u043e\u043d\u043d\u043e\u0441\u0442\u0438: \u0437\u0430\u0434\u0430\u0447\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u044f\u044e\u0442\u0441\u044f \u043d\u0435 \u043f\u043e \u043f\u043e\u0440\u044f\u0434\u043a\u0443, \u0430 \u0432 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e\u043c \u043f\u043e\u0440\u044f\u0434\u043a\u0435. \u041f\u0440\u043e\u0441\u0442\u044b\u043c\u0438 \u0441\u043b\u043e\u0432\u0430\u043c\u0438: \u0430\u0441\u0438\u043d\u0445\u0440\u043e\u043d\u043d\u043e\u0441\u0442\u044c - \u044d\u0442\u043e \u043d\u0435 \u0441\u0438\u043d\u0445\u0440\u043e\u043d\u043d\u043e\u0441\u0442\u044c.</p>","tags":["async","\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]},{"location":"coding/async.html#_1","title":"\u041f\u0440\u0438\u043c\u0435\u0440","text":"<ul> <li>\u041e\u0434\u0438\u043d \u043f\u043e\u0442\u043e\u043a<ul> <li>\u0422\u044b \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0448\u044c \u0432 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d, \u0437\u0430\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0448\u044c \u0435\u0434\u0443. \u041a\u0430\u0441\u0441\u0438\u0440 \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442 \u0442\u0432\u043e\u044e \u043e\u043f\u043b\u0430\u0442\u0443 \u0438 \u0443\u0445\u043e\u0434\u0438\u0442 \u0433\u043e\u0442\u043e\u0432\u0438\u0442\u044c \u0431\u0443\u0440\u0433\u0435\u0440. \u041f\u043e\u043a\u0430 \u043d\u0435 \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d \u0431\u0443\u0440\u0433\u0435\u0440 - \u0434\u0440\u0443\u0433\u0438\u0435 \u043a\u043b\u0438\u0435\u043d\u0442\u044b \u043d\u0435 \u043c\u043e\u0433\u0443\u0442 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u0441\u0432\u043e\u0439 \u0437\u0430\u043a\u0430\u0437.</li> </ul> </li> <li>\u041d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043f\u043e\u0442\u043e\u043a\u043e\u0432<ul> <li>\u0422\u043e \u0436\u0435 \u0441\u0430\u043c\u043e\u0435, \u0447\u0442\u043e \u0438 \u043e\u0434\u0438\u043d \u043f\u043e\u0442\u043e\u043a, \u043d\u043e \u043a\u0430\u0441\u0441 \u0431\u043e\u043b\u044c\u0448\u0435, \u0447\u0435\u043c \u043e\u0434\u043d\u0430</li> </ul> </li> <li>\u0410\u0441\u0438\u043d\u0445\u0440\u043e\u043d\u043d\u043e\u0441\u0442\u044c<ul> <li>\u0422\u044b \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0448\u044c \u0432 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d, \u0437\u0430\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0448\u044c \u0434\u0432\u0430 \u0431\u0443\u0440\u0433\u0435\u0440\u0430. \u041a\u0430\u0441\u0441\u0438\u0440 \u043f\u0435\u0440\u0435\u0434\u0430\u0451\u0442 \u0442\u0432\u043e\u0439 \u0437\u0430\u043a\u0430\u0437 \u043f\u043e\u0432\u0430\u0440\u0443, \u0434\u0430\u0451\u0442 \u0442\u0435\u0431\u0435 \u043d\u043e\u043c\u0435\u0440 \u0438 \u0433\u043e\u0432\u043e\u0440\u0438\u0442 \u043f\u043e\u0434\u043e\u0436\u0434\u0430\u0442\u044c. \u0422\u044b \u043e\u043f\u043b\u0430\u0447\u0438\u0432\u0430\u0435\u0448\u044c \u0437\u0430\u043a\u0430\u0437 \u0438 \u043e\u0436\u0438\u0434\u0430\u0435\u0448\u044c \u0441\u0432\u043e\u0435\u0439 \u043e\u0447\u0435\u0440\u0435\u0434\u0438. \u041f\u043e\u0432\u0430\u0440 \u043c\u043e\u0436\u0435\u0442 \u0433\u043e\u0442\u043e\u0432\u0438\u0442\u044c \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0437\u0430\u043a\u0430\u0437\u043e\u0432, \u0430 \u043a\u0430\u0441\u0441\u0438\u0440 \u0432 \u044d\u0442\u043e \u0432\u0440\u0435\u043c\u044f \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u0435\u0442 \u0434\u0440\u0443\u0433\u0438\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432.</li> </ul> </li> </ul>","tags":["async","\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]},{"location":"coding/async.html#_2","title":"\u0421\u0441\u044b\u043b\u043a\u0438","text":"<ul> <li>https://fastapi.tiangolo.com/async/#concurrency-and-burgers</li> </ul>","tags":["async","\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]},{"location":"coding/jitter.html","title":"\u0414\u0436\u0438\u0442\u0442\u0435\u0440","text":"<p>\u0414\u0436\u0438\u0442\u0442\u0435\u0440 (\u0430\u043d\u0433\u043b. jitter - \u0434\u0440\u043e\u0436\u0430\u043d\u0438\u0435) - \u044d\u0442\u043e \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043a TTL, \u0447\u0442\u043e\u0431\u044b \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 \u0437\u0430\u043f\u0438\u0441\u0435\u0439 \u043d\u0435 \u0438\u0441\u0442\u0435\u043a\u0430\u043b\u043e/\u0432\u044b\u043f\u043e\u043b\u043d\u044f\u043b\u043e\u0441\u044c \u0440\u0430\u0437\u043e\u043c.</p> <p>\u0415\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 <code>TTL = 60s</code> \u0438 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043a\u044d\u0448\u0435\u0439, \u0442\u043e \u0447\u0435\u0440\u0435\u0437 60 \u0441\u0435\u043a\u0443\u043d\u0434 \u043e\u043d\u0438 \u0432\u043c\u0435\u0441\u0442\u0435 \u0438\u0441\u0442\u0435\u043a\u0443\u0442 \u0438 \u043f\u043e\u0439\u0434\u0443\u0442 \u043e\u0431\u043d\u043e\u0432\u043b\u044f\u0442\u044c\u0441\u044f, \u0441\u043e\u0437\u0434\u0430\u0432\u0430\u044f \u043f\u0438\u043a\u043e\u0432\u044b\u0435 \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0438. \u0415\u0441\u043b\u0438 \u0436\u0435 <code>TTL = 60s +- random(0..10s)</code>, \u0442\u043e \u043e\u0434\u0438\u043d \u043a\u044d\u0448 \u0431\u0443\u0434\u0435\u0442 \u0434\u043b\u0438\u0442\u044c\u0441\u044f 63 \u0441\u0435\u043a\u0443\u043d\u0434\u044b, \u0432\u0442\u043e\u0440\u043e\u0439 - 58 \u0441\u0435\u043a\u0443\u043d\u0434, \u0442\u0440\u0435\u0442\u0438\u0439 - 61 \u0441\u0435\u043a\u0443\u043d\u0434\u0443 \u0438 \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 \u043a\u044d\u0448\u0430 \u0440\u0430\u0437\u043c\u0430\u0437\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438.</p> <p>\u041f\u0440\u0438\u043c\u0435\u0440\u044b \u043a\u043e\u0434\u0430:</p> <pre><code>def jitter(ttl: int) -&gt; int:\n    return ttl + random.randint(-ttl//10, ttl//10)\n\ndef jitter_abs(ttl: float, delta: float) -&gt; float:\n    \"\"\" jitter_abs(10.0, 2.0) -&gt; [8.0..12.0] \"\"\"\n    return ttl + random.uniform(-delta, delta)\n\ndef jitter_pct(ttl: float, pct: float) -&gt; float:\n    \"\"\" jitter_pct(100.0, 0.1) -&gt; [90.0..110.0] \"\"\"\n    delta = ttl * pct\n    return ttl + random.uniform(-delta, delta)\n</code></pre>","tags":["\u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435","\u043a\u044d\u0448\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435"]},{"location":"coding/negative_cache.html","title":"\u041d\u0435\u0433\u0430\u0442\u0438\u0432\u043d\u043e\u0435 \u043a\u044d\u0448\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435","text":"<p>\u041d\u0435\u0433\u0430\u0442\u0438\u0432\u043d\u043e\u0435 \u043a\u044d\u0448\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 - \u044d\u0442\u043e \u043a\u043e\u0433\u0434\u0430 \u043c\u044b \u043a\u044d\u0448\u0438\u0440\u0443\u0435\u043c \u043e\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430 \u0438\u043b\u0438 \u043e\u0448\u0438\u0431\u043a\u0443.</p> <p>\u0418\u0434\u0435\u044f \u043f\u0440\u043e\u0441\u0442\u0430\u044f: \u0435\u0441\u043b\u0438 \u043d\u0438\u0447\u0435\u0433\u043e \u043d\u0435\u0442, \u0442\u043e \u0434\u043b\u044f \u0443\u0442\u043e\u0447\u043d\u0435\u043d\u0438\u044f \u044d\u0442\u043e\u0433\u043e \u0444\u0430\u043a\u0442\u0430 \u0432 \u043a\u043e\u0440\u043e\u0442\u043a\u0438\u0439 \u043f\u0435\u0440\u0438\u043e\u0434 \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043d\u0435 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043f\u0435\u0440\u0435\u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0440\u0435\u0441\u0443\u0440\u0441\u044b.</p>","tags":["\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430","\u043a\u044d\u0448\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435"]},{"location":"coding/negative_cache.html#_1","title":"\u0417\u0430\u0447\u0435\u043c?","text":"<ul> <li>\u0421\u043d\u044f\u0442\u044c \u043b\u0438\u0448\u043d\u044e\u044e \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0443. \u0427\u0430\u0441\u0442\u044b\u0435 \u0437\u0430\u043f\u0440\u043e\u0441\u044b \u043a \u043d\u0435\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u043c \u0434\u0430\u043d\u043d\u044b\u043c \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u044e\u0442 \u0431\u0438\u0442\u044c \u043f\u043e \u0431\u0430\u0437\u0435 \u0434\u0430\u043d\u043d\u044b\u0445 \u0438\u043b\u0438 \u0441\u0435\u0440\u0432\u0438\u0441\u0443.</li> <li>\u0417\u0430\u0449\u0438\u0442\u0438\u0442\u044c\u0441\u044f \u043e\u0442 \u0433\u0440\u043e\u043c\u043e\u0432\u043e\u0433\u043e \u0441\u0442\u0430\u0434\u0430: \u0442\u044b\u0441\u044f\u0447\u0438 \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u0445 \u043f\u0440\u043e\u043c\u0430\u0445\u043e\u0432 \u043d\u0435 \u043f\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044e\u0442\u0441\u044f \u0432 \u0442\u044b\u0441\u044f\u0447\u0438 \u043f\u043e\u0445\u043e\u0434\u043e\u0432 \u0432 \u0411\u0414.</li> <li>\u0417\u0430\u0449\u0438\u0442\u0430 \u043e\u0442 cache miss attack (\u0430\u0442\u0430\u043a\u0438 \u0447\u0435\u0440\u0435\u0437 \u043f\u0440\u043e\u043c\u0430\u0445\u0438 \u043a\u044d\u0448\u0430). \u0417\u0430\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u0434\u0430\u043d\u043d\u044b\u0435, \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u043d\u0435\u0442 \u0432 \u043a\u044d\u0448\u0435, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0438\u0445 \u043d\u0435\u0442 \u0438 \u0432 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0435.</li> </ul>","tags":["\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430","\u043a\u044d\u0448\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435"]},{"location":"coding/thundering_herd.html","title":"\u0413\u0440\u043e\u043c\u043e\u0432\u043e\u0435 \u0441\u0442\u0430\u0434\u043e","text":"<p>\u0413\u0440\u043e\u043c\u043e\u0432\u043e\u0435 \u0441\u0442\u0430\u0434\u043e (thundering herd) - \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u043e\u0432/\u043f\u043e\u0442\u043e\u043a\u043e\u0432 \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e \u043f\u0440\u043e\u0441\u044b\u043f\u0430\u044e\u0442\u0441\u044f \u0438 \u043f\u044b\u0442\u0430\u044e\u0442\u0441\u044f \u0432\u0437\u044f\u0442\u044c \u043e\u0434\u0438\u043d \u0440\u0435\u0441\u0443\u0440\u0441, \u0447\u0442\u043e \u043f\u0440\u0438\u0432\u043e\u0434\u0438\u0442 \u043a \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u043d\u043e\u0439 \u043e\u0434\u043d\u043e\u043c\u043e\u043c\u0435\u043d\u0442\u043d\u043e\u0439 \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0435.</p>","tags":["\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]},{"location":"coding/thundering_herd.html#_1","title":"\u041f\u0440\u0438\u043c\u0435\u0440","text":"<p>\u0420\u0435\u0441\u0443\u0440\u0441 \u0431\u044b\u043b \u043d\u0435\u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0432\u0440\u0435\u043c\u044f, \u043f\u043e\u0442\u043e\u043c \u043e\u043d \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044f \u0432 \u0440\u0430\u0431\u043e\u0447\u0435\u0435 \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0438 \u0432\u0441\u0435 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u044b/\u043f\u043e\u0442\u043e\u043a\u0438 \u043e\u0431\u0440\u0430\u0449\u0430\u044e\u0442\u0441\u044f \u043a \u043d\u0435\u043c\u0443 \u0440\u0430\u0437\u043e\u043c.</p>","tags":["\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]},{"location":"coding/thundering_herd.html#_2","title":"\u0420\u0435\u0448\u0435\u043d\u0438\u044f","text":"<ul> <li>\u041c\u043e\u0434\u0435\u043b\u044c \u0441 \u044d\u043a\u0441\u043a\u043b\u044e\u0437\u0438\u0432\u043d\u043e\u0439 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u043e\u0439 \u0441\u043e\u0431\u044b\u0442\u0438\u044f \u043e\u0434\u043d\u043e\u043c\u0443 \u0432\u043e\u0440\u043a\u0435\u0440\u0443 (accept-mutex)</li> <li>\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0446\u0438\u0438: \u0441\u0435\u043c\u0430\u0444\u043e\u0440\u044b, \u043e\u0447\u0435\u0440\u0435\u0434\u0438, backoff/jitter \u043f\u0435\u0440\u0435\u0434 \u043f\u043e\u0432\u0442\u043e\u0440\u043d\u043e\u0439 \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u043e\u0439, Mutex</li> <li>TTL + Jitter</li> </ul>","tags":["\u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0430"]}]}